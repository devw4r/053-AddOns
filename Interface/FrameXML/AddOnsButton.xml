<Ui xmlns="http://www.blizzard.com/wow/ui/">\n    <!-- Button added to the main menu bar for toggling the AddOn manager frame -->\n    <Button name="AddOnsMicroButton" inherits="MainMenuBarMicroButton" parent="MainMenuBarArtFrame">\n        <Anchors>\n            <Anchor point="BOTTOMLEFT" relativeTo="TalentMicroButton" relativePoint="BOTTOMRIGHT">\n                <Offset>\n                    <AbsDimension x="25" y="0"/>\n                </Offset>\n            </Anchor>\n        </Anchors>\n        <Scripts>\n            <OnLoad>\n                LoadMicroButtonTextures("AddOns");\n                this.tooltipText = MicroButtonTooltipText(TEXT(ADDONS_BUTTON), "TOGGLEDONTS")\n            </OnLoad>\n            <OnClick>\n                ToggleFrame(AddOnManagerFrame);\n            </OnClick>\n        </Scripts>\n    </Button>\n</Ui>
